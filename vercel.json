{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "REPLACE_API_URL/api/:path*" },
    { "source": "/admin-panel/:path*", "destination": "/admin-panel/index.html" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
